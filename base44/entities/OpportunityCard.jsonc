{
  "name": "OpportunityCard",
  "type": "object",
  "properties": {
    "alias": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": [
        "Concept",
        "Prototype",
        "Patent Pending",
        "Patent Granted",
        "Seeking Co-Inventor",
        "Seeking Funding"
      ]
    },
    "funding_ask": {
      "type": "number"
    },
    "equity_offered": {
      "type": "number"
    },
    "headline": {
      "type": "string"
    },
    "problem_statement": {
      "type": "string"
    },
    "solution_summary": {
      "type": "string"
    },
    "market_size": {
      "type": "string"
    },
    "ip_valuation": {
      "type": "number"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "jurisdiction": {
      "type": "string"
    },
    "alignment_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "live",
        "matched",
        "closed"
      ],
      "default": "draft"
    },
    "matched_investors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contact_email_encrypted": {
      "type": "string"
    },
    "verified_inventor": {
      "type": "boolean",
      "default": false,
      "description": "True if inventor identity and patents have been verified by admin"
    },
    "patent_docs_verified": {
      "type": "boolean",
      "default": false,
      "description": "True if patent documents have been reviewed and confirmed"
    },
    "identity_verified": {
      "type": "boolean",
      "default": false,
      "description": "True if inventor identity has been confirmed"
    },
    "verification_date": {
      "type": "string",
      "description": "Date when verified_inventor status was set"
    },
    "verified_by_admin": {
      "type": "string",
      "description": "Email of admin who verified this listing"
    },
    "verification_notes": {
      "type": "string",
      "description": "Admin notes from the verification review"
    }
  },
  "required": [
    "alias",
    "headline",
    "category"
  ]
}