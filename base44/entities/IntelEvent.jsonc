{
  "name": "IntelEvent",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "insight",
        "threat",
        "opportunity",
        "cluster",
        "entity_link",
        "diff"
      ],
      "description": "Event classification"
    },
    "module": {
      "type": "string",
      "enum": [
        "InsightEngine",
        "ThreatMonitor",
        "OpportunityEngine",
        "EntityLinker",
        "ClusterDetection"
      ],
      "description": "Which intelligence module generated this"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical",
        "success"
      ]
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "source_id": {
      "type": "string",
      "description": "ID of the entity that triggered this event"
    },
    "source_type": {
      "type": "string",
      "description": "Entity type (HybridInvention, PriorArtEntry, etc.)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "number",
      "description": "Risk or opportunity score 0-100"
    },
    "action_url": {
      "type": "string"
    },
    "acknowledged": {
      "type": "boolean",
      "default": false
    },
    "patch": {
      "type": "string",
      "description": "Auto-generated repair suggestion or diff"
    },
    "cluster_id": {
      "type": "string"
    },
    "linked_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "type",
    "module",
    "severity",
    "title"
  ]
}