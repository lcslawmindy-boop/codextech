{
  "name": "InvestmentOpportunity",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "anon_handle": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Vacuum Energy",
        "Scalar EM",
        "Bioelectromagnetics",
        "Resonance Devices",
        "Free Energy",
        "Defense Technology",
        "Health Technology",
        "Other"
      ]
    },
    "stage": {
      "type": "string",
      "enum": [
        "Concept",
        "Prototype",
        "Patent Filed",
        "Patent Granted",
        "Pre-Revenue",
        "Revenue Stage"
      ],
      "default": "Concept"
    },
    "summary": {
      "type": "string"
    },
    "problem_solved": {
      "type": "string"
    },
    "tech_approach": {
      "type": "string"
    },
    "seeking_usd": {
      "type": "number"
    },
    "equity_offered": {
      "type": "number"
    },
    "use_of_funds": {
      "type": "string"
    },
    "ip_status": {
      "type": "string"
    },
    "tam_usd_millions": {
      "type": "number"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "matched_investors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contact_method": {
      "type": "string"
    },
    "is_anonymous": {
      "type": "boolean",
      "default": true
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Active",
        "Matched",
        "Funded",
        "Closed"
      ],
      "default": "Draft"
    }
  },
  "required": [
    "title",
    "category",
    "summary"
  ]
}