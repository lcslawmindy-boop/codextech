{
  "name": "EncryptedMessage",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "sender_email": {
      "type": "string"
    },
    "sender_alias": {
      "type": "string"
    },
    "recipient_email": {
      "type": "string"
    },
    "recipient_alias": {
      "type": "string"
    },
    "encrypted_content": {
      "type": "string",
      "description": "Encrypted message body (AES-256)"
    },
    "deal_id": {
      "type": "string",
      "description": "Associated deal/transaction if applicable"
    },
    "read": {
      "type": "boolean",
      "default": false
    },
    "read_timestamp": {
      "type": "string"
    },
    "created_date": {
      "type": "string"
    }
  },
  "required": [
    "conversation_id",
    "sender_email",
    "recipient_email",
    "encrypted_content"
  ]
}