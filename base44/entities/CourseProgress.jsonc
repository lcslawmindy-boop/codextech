{
  "name": "CourseProgress",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "course_title": {
      "type": "string"
    },
    "completed_lessons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_lesson": {
      "type": "string"
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string",
      "description": "Optional notes about this course progress record",
      "maxLength": 1000
    }
  },
  "required": [
    "user_email",
    "course_title"
  ]
}