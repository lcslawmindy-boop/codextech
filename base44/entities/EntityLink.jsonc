{
  "name": "EntityLink",
  "type": "object",
  "properties": {
    "from_id": {
      "type": "string"
    },
    "from_type": {
      "type": "string",
      "enum": [
        "HybridInvention",
        "PriorArtEntry",
        "PatentClaim",
        "OpportunityCard",
        "User"
      ]
    },
    "from_label": {
      "type": "string"
    },
    "to_id": {
      "type": "string"
    },
    "to_type": {
      "type": "string",
      "enum": [
        "HybridInvention",
        "PriorArtEntry",
        "PatentClaim",
        "OpportunityCard",
        "User",
        "IntelCluster"
      ]
    },
    "to_label": {
      "type": "string"
    },
    "relation": {
      "type": "string",
      "enum": [
        "cites",
        "conflicts_with",
        "extends",
        "invalidates",
        "belongs_to",
        "competes_with",
        "licenses_to",
        "clusters_with"
      ]
    },
    "confidence": {
      "type": "number",
      "description": "0-1 confidence score"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "from_id",
    "from_type",
    "to_id",
    "to_type",
    "relation"
  ]
}