{
  "name": "NodeClick",
  "type": "object",
  "properties": {
    "node_id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "group": {
      "type": "string"
    },
    "click_count": {
      "type": "integer",
      "default": 0
    },
    "description": {
      "type": "string",
      "description": "Optional notes about this node click event",
      "maxLength": 1000
    }
  },
  "required": [
    "node_id",
    "label",
    "group",
    "click_count"
  ]
}