{
  "name": "InventionBuildProject",
  "type": "object",
  "properties": {
    "invention_name": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Parts Ordered",
        "Parts Received",
        "Assembly in Progress",
        "Wiring & Connections",
        "Testing",
        "Calibration",
        "Completed",
        "On Hold",
        "Issue Flagged"
      ],
      "default": "Parts Ordered"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "progress_percent": {
      "type": "integer",
      "default": 0
    },
    "notes": {
      "type": "string"
    },
    "admin_notes": {
      "type": "string"
    },
    "parts_list": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "ordered": {
            "type": "boolean"
          },
          "received": {
            "type": "boolean"
          },
          "cost": {
            "type": "string"
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          },
          "date": {
            "type": "string"
          }
        }
      }
    },
    "started_date": {
      "type": "string"
    },
    "target_date": {
      "type": "string"
    },
    "completed_date": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "resolved": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "required": [
    "invention_name",
    "user_email",
    "status"
  ]
}