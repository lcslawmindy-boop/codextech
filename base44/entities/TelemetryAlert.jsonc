{
  "name": "TelemetryAlert",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "device_id": {
      "type": "string"
    },
    "device_name": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "channel_label": {
      "type": "string"
    },
    "condition": {
      "type": "string",
      "enum": [
        "above",
        "below",
        "equals"
      ],
      "default": "above"
    },
    "threshold": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ],
      "default": "warning"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "triggered_at": {
      "type": "string"
    },
    "triggered_value": {
      "type": "number"
    },
    "acknowledged": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_email",
    "device_id",
    "channel",
    "condition",
    "threshold",
    "severity"
  ]
}