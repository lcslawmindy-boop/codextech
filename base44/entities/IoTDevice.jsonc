{
  "name": "IoTDevice",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "Friendly device name"
    },
    "device_id": {
      "type": "string",
      "description": "Unique device identifier (used in API calls)"
    },
    "api_key": {
      "type": "string",
      "description": "Secret key for HTTP ingest authentication"
    },
    "protocol": {
      "type": "string",
      "enum": [
        "HTTP",
        "MQTT"
      ],
      "default": "HTTP"
    },
    "description": {
      "type": "string"
    },
    "invention_name": {
      "type": "string",
      "description": "Associated invention/build"
    },
    "sensors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "error"
      ],
      "default": "inactive"
    },
    "last_seen": {
      "type": "string"
    },
    "total_readings": {
      "type": "integer",
      "default": 0
    }
  },
  "required": [
    "user_email",
    "name",
    "device_id",
    "api_key"
  ]
}