{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Unique order ID (e.g., ORD-2026-001)"
    },
    "customer_email": {
      "type": "string",
      "description": "Customer email address"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer full name"
    },
    "kit_name": {
      "type": "string",
      "description": "Name of the kit purchased"
    },
    "invention_name": {
      "type": "string",
      "description": "Which invention this is for"
    },
    "price_cents": {
      "type": "integer",
      "description": "Total price in cents"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "shipped",
        "delivered",
        "cancelled"
      ],
      "default": "pending",
      "description": "Order status"
    },
    "stripe_payment_intent": {
      "type": "string",
      "description": "Stripe payment intent ID"
    },
    "tracking_number": {
      "type": "string",
      "description": "Shipping tracking number"
    },
    "shipping_address": {
      "type": "string",
      "description": "Full shipping address"
    },
    "ordered_at": {
      "type": "string",
      "format": "date-time",
      "description": "When order was placed"
    },
    "shipped_at": {
      "type": "string",
      "format": "date-time",
      "description": "When order was shipped"
    },
    "estimated_delivery": {
      "type": "string",
      "format": "date",
      "description": "Estimated delivery date"
    },
    "notes": {
      "type": "string",
      "description": "Order notes"
    }
  },
  "required": [
    "customer_email",
    "kit_name",
    "invention_name",
    "price_cents"
  ]
}