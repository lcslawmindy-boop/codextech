{
  "name": "Referral",
  "type": "object",
  "properties": {
    "referrer_email": {
      "type": "string"
    },
    "referrer_code": {
      "type": "string"
    },
    "referred_email": {
      "type": "string"
    },
    "referred_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "expired"
      ],
      "default": "pending"
    },
    "membership_tier": {
      "type": "string",
      "enum": [
        "builder",
        "researcher",
        "pro"
      ]
    },
    "store_credit_amount": {
      "type": "number",
      "default": 0
    },
    "created_date": {
      "type": "string"
    },
    "completed_date": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "description": "Optional notes about this referral",
      "maxLength": 1000
    }
  },
  "required": [
    "referrer_email",
    "referrer_code"
  ]
}