{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "subscription_status": {
      "type": "string"
    },
    "stripe_customer_id": {
      "type": "string"
    },
    "subscription_id": {
      "type": "string"
    },
    "admin_access_granted": {
      "type": "boolean",
      "default": false
    },
    "subscription_activated_at": {
      "type": "string",
      "description": "ISO timestamp when subscription first became active \u2014 used for drip email targeting"
    }
  },
  "required": []
}