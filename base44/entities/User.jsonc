{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "subscription_status": {
      "type": "string"
    },
    "stripe_customer_id": {
      "type": "string"
    },
    "subscription_id": {
      "type": "string"
    },
    "admin_access_granted": {
      "type": "boolean",
      "default": false
    }
  }
}