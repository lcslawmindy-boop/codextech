{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "subscription_status": {
      "type": "string",
      "description": "Set by Stripe webhook: active, canceled, past_due, etc."
    },
    "stripe_customer_id": {
      "type": "string"
    },
    "subscription_id": {
      "type": "string"
    },
    "admin_access_granted": {
      "type": "boolean",
      "default": false
    },
    "nda_accepted": {
      "type": "boolean",
      "default": false,
      "description": "True once the user has signed and verified the NDA"
    }
  },
  "required": []
}