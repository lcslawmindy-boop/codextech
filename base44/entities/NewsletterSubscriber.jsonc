{
  "name": "NewsletterSubscriber",
  "type": "object",
  "properties": {
    "email": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "unsubscribed"
      ],
      "default": "active"
    },
    "description": {
      "type": "string",
      "description": "Optional notes about this subscriber",
      "maxLength": 1000
    }
  },
  "required": [
    "email"
  ]
}