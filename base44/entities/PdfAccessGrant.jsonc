{
  "name": "PdfAccessGrant",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "description": "Email address of the user granted PDF download access"
    },
    "tier": {
      "type": "string",
      "enum": [
        "elite",
        "gov",
        "brief_pack"
      ],
      "description": "Membership tier or product the user purchased"
    },
    "product": {
      "type": "string",
      "description": "Specific product granted (e.g. 'Technical Brief Pack', 'MEG System Architecture')"
    },
    "download_url": {
      "type": "string",
      "description": "Direct URL or signed URL for the PDF file"
    },
    "stripe_session_id": {
      "type": "string",
      "description": "Stripe checkout session ID for verification"
    },
    "granted_by": {
      "type": "string",
      "description": "Admin email who granted access"
    },
    "notes": {
      "type": "string",
      "description": "Optional admin notes"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this grant is currently active"
    },
    "email_sent": {
      "type": "boolean",
      "default": false,
      "description": "Whether the download link email has been sent"
    }
  },
  "required": [
    "email",
    "tier"
  ]
}